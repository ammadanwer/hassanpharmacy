  "html": "<form class=\"simple-modal\"><div class=\"modal-head\"><h2>Add Medical Product</h2><button type=\"button\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-x\"><path d=\"M18 6 6 18\"></path><path d=\"m6 6 12 12\"></path></svg></button></div><div class=\"simple-modal-body three\"><label><span class=\"field-title\">Bar Code </span><input type=\"text\" placeholder=\"Enter barcode.\" value=\"\"></label><label><span class=\"field-title\">Name </span><input required=\"\" type=\"text\" placeholder=\"Enter Name\" value=\"\"></label><label class=\"lookup-field\"><span class=\"field-title\">Medical Formula </span><div class=\"input-action lookup-action \"><input placeholder=\"Select Medicine Formula\" value=\"\"><button type=\"button\">+ Add as New</button></div><input type=\"hidden\" readonly=\"\" value=\"\"></label><label class=\"lookup-field\"><span class=\"field-title\">Category </span><div class=\"input-action lookup-action no-action\"><input placeholder=\"Select Category\" value=\"\"></div><input type=\"hidden\" readonly=\"\" value=\"\"></label><label class=\"product-measure-field\"><span class=\"field-title\">Dose</span><span class=\"product-measure-inputs\"><input type=\"text\" placeholder=\"Enter Dose\" value=\"\"><input type=\"text\" placeholder=\"Sel. Unit\" value=\"\"></span></label><label><span class=\"field-title\">Generic Name </span><input type=\"text\" placeholder=\"Enter Generic Name\" value=\"\"></label><label class=\"lookup-field\"><span class=\"field-title\">Manufacturer Name </span><div class=\"input-action lookup-action no-action\"><input placeholder=\"Select Manufacturer\" value=\"\"></div><input type=\"hidden\" readonly=\"\" value=\"\"></label><label class=\"check-field\"><input type=\"checkbox\"> Prescription needed for this medicine</label></div><div class=\"modal-actions\"><span></span><button class=\"primary\">Add</button></div></form>",
